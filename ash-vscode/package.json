{
  "name": "ash-language",
  "displayName": "Ash Language",
  "description": "Language support for the Ash programming language",
  "version": "0.1.0",
  "publisher": "lorenzovecchio",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:ash"],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ash",
        "aliases": ["Ash", "ash"],
        "extensions": [".ash"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ash",
        "scopeName": "source.ash",
        "path": "./syntaxes/ash.tmLanguage.json"
      }
    ]
  }
}
