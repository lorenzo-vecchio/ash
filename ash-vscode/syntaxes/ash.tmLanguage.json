{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Ash",
  "scopeName": "source.ash",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#function-definition" },
    { "include": "#type-definition" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#namespace-call" },
    { "include": "#namespace-property" },
    { "include": "#function-call" },
    { "include": "#method-call" },
    { "include": "#type-annotation" },
    { "include": "#type-names" },
    { "include": "#operators" },
    { "include": "#variables" }
  ],
  "repository": {

    "comments": {
      "name": "comment.line.hash.ash",
      "match": "#.*$"
    },

    "strings": {
      "name": "string.quoted.double.ash",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.ash",
          "match": "\\\\."
        },
        {
          "name": "meta.interpolation.ash",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.ash" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.interpolation.end.ash" } },
          "patterns": [
            { "include": "#namespace-call" },
            { "include": "#function-call" },
            { "include": "#operators" },
            { "include": "#numbers" },
            { "include": "#variables" }
          ]
        }
      ]
    },

    "function-definition": {
      "match": "\\b(fn)\\s+([a-z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.function.ash" },
        "2": { "name": "entity.name.function.ash" }
      }
    },

    "type-definition": {
      "match": "\\b(type)\\s+([A-Za-z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.type.ash" },
        "2": { "name": "entity.name.type.ash" }
      }
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ash",
          "match": "\\b(if|else|while|for|in|match|return|panic|use|then)\\b"
        },
        {
          "name": "keyword.declaration.ash",
          "match": "\\b(let|mut)\\b"
        },
        {
          "name": "keyword.other.ash",
          "match": "\\b(move|await)\\b"
        }
      ]
    },

    "constants": {
      "name": "constant.language.ash",
      "match": "\\b(true|false|none|None|Some|Ok|Err)\\b"
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.ash",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.ash",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "namespace-call": {
      "match": "\\b(math|file|http|json|re|env|go|db|cache|queue|auth|mail|store|ai)\\.([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "entity.name.namespace.ash" },
        "2": { "name": "entity.name.function.ash" }
      }
    },

    "namespace-property": {
      "match": "\\b(math|file|http|json|re|env|go|db|cache|queue|auth|mail|store|ai)\\.([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "entity.name.namespace.ash" },
        "2": { "name": "variable.other.member.ash" }
      }
    },

    "function-call": {
      "match": "\\b([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "name": "entity.name.function.ash"
    },

    "method-call": {
      "match": "\\.([a-z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "captures": {
        "1": { "name": "entity.name.function.ash" }
      }
    },

    "type-annotation": {
      "match": ":\\s*([A-Z][a-zA-Z0-9_]*|int|float|str|bool|void)",
      "captures": {
        "1": { "name": "entity.name.type.ash" }
      }
    },

    "type-names": {
      "name": "entity.name.type.ash",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.ash",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.ash",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.pipeline.ash",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.ash",
          "match": "=>|->"
        },
        {
          "name": "keyword.operator.null.ash",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.safe-nav.ash",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.range.ash",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.arithmetic.ash",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.assignment.ash",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.propagate.ash",
          "match": "!(?!=)"
        },
        {
          "name": "keyword.operator.optional.ash",
          "match": "\\?(?![?.])"
        }
      ]
    },

    "variables": {
      "name": "variable.other.ash",
      "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
    }

  }
}
